        "jsonBody": "={\n  \"data\": {\n    \"type\": \"event\",\n    \"attributes\": {\n      \"metric\": {\n        \"data\": {\n          \"type\": \"metric\",\n          \"attributes\": {\n            \"name\": \"Abandoned Cart Stage 3 Discount\"\n          }\n        }\n      },\n      \"properties\": {\n        \"cart_items\": \"{{ $json.lineItems }}\",\n        \"cart_total\": \"{{ $json.totalPrice }}\",\n        \"checkout_url\": \"{{ $json.checkoutUrl }}\",\n        \"discount_code\": \"STANDARD10\"\n      },\n      \"profile\": {\n        \"data\": {\n          \"type\": \"profile\",\n          \"attributes\": {\n            \"email\": \"{{ $json.customerEmail }}\"\n          }\n        }\n      }\n    }\n  }\n}",
